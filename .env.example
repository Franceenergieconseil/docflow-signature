# ===================================
# Configuration DocFlow - Exemple
# ===================================

# Environment
NODE_ENV=production

# Database Configuration
# Chemin vers le fichier SQLite (utilisé automatiquement par Docker)
DATABASE_PATH=/app/data/database.sqlite

# Server Configuration
PORT=3000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# DocuSeal Integration
DOCUSEAL_API_KEY=your_docuseal_api_key
DOCUSEAL_BASE_URL=https://api.docuseal.co

# Google AI (si utilisé)
GOOGLE_AI_API_KEY=your_google_ai_api_key_if_needed

# CORS (optionnel)
# CORS_ORIGIN=https://yourdomain.com
