# ===================================
# Configuration DocFlow Signature
# ===================================

# --- SÉCURITÉ ---
# JWT secret pour signer les tokens d'authentification (changez en production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# --- DOCUSEAL INTEGRATION ---
# Clé API pour l'intégration DocuSeal
DOCUSEAL_API_KEY=your_docuseal_api_key_here

# URL de votre instance DocuSeal (sans /api à la fin)
DOCUSEAL_API_URL=https://your-docuseal-instance.com

# Secret partagé pour la vérification de signature des webhooks DocuSeal
# ⚠️ IMPORTANT : Ce secret doit être identique à celui configuré dans DocuSeal
DOCUSEAL_WEBHOOK_SECRET=your_webhook_secret_32_chars_min

# --- BASE DE DONNÉES ---
# Chemin vers le fichier SQLite (en production Docker: /app/data/database.sqlite)
DATABASE_PATH=./database.sqlite

# --- SERVEUR ---
# Port d'écoute du serveur
PORT=3000

# Environnement (development ou production)
NODE_ENV=development

# --- GOOGLE AI (Optionnel) ---
# Si vous utilisez Gemini AI pour des fonctionnalités avancées
GEMINI_API_KEY=your_gemini_api_key_optional

# --- APPLICATION (pour les webhooks) ---
# URL publique de l'application (nécessaire pour les webhooks DocuSeal)
APP_URL=https://docflow.f-energieconseil.fr
